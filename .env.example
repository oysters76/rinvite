# Copy to .env and fill in. Compose reads this for variable substitution.

# Required — the JWT signing key (min 32 bytes). Generate one:
#   openssl rand -hex 32
JWT_SECRET=

# Optional — Postgres password (defaults to "auth" if unset).
POSTGRES_PASSWORD=auth

# Base URL used to build shareable invite links, e.g. https://your-domain
# (defaults to http://localhost:3000). Links look like {PUBLIC_BASE_URL}/i/<token>.
PUBLIC_BASE_URL=

# ===== E-invite delivery ====================================================
# All optional. If a provider's keys are unset the message is logged to the
# server console instead of sent, so local dev works with no accounts.

# Email — Resend (https://resend.com). Both must be set to send real email.
RESEND_API_KEY=
EMAIL_FROM=Rinvite <invites@your-domain>

# WhatsApp — Twilio (https://www.twilio.com/docs/whatsapp). All three to send.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp-enabled sender in E.164, e.g. +14155238886 (Twilio sandbox number).
TWILIO_WHATSAPP_FROM=
# Optional — a Meta-approved template's ContentSid, required for production
# business-initiated messages (freeform Body only works in the sandbox / 24h
# session window). The rendered message is passed as content variable {{1}}.
TWILIO_CONTENT_SID=

# ===== Message template overrides ===========================================
# Optional — point at your own files to override the built-in templates.
# EMAIL_TEMPLATE_HTML=./assets/messages/email.html
# EMAIL_TEMPLATE_TEXT=./assets/messages/email.txt
# EMAIL_SUBJECT=./assets/messages/email-subject.txt
# WHATSAPP_TEMPLATE=./assets/messages/whatsapp.txt
